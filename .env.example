# TMDB API Configuration
# Get your API key from: https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here
NEXT_PUBLIC_TMDB_BASE_URL=https://api.themoviedb.org/3
NEXT_PUBLIC_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# YouTube API Configuration
# Get your API key from: https://console.cloud.google.com
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# Solana Configuration
# Local validator: http://localhost:8899
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
NEXT_PUBLIC_RPC_URL=http://localhost:8899

# Program ID
# Change this after deploying your own program
NEXT_PUBLIC_PROGRAM_ID=ApfCLKKr7Y6GX9qKWujhDGmSNvdN93tNidyPe2hyB9jL

# Network Configuration
NEXT_PUBLIC_IS_MAINNET=false
NEXT_PUBLIC_CLUSTER=devnet
NEXT_PUBLIC_NETWORK=mainnet

# USDC Mint Address
# Devnet USDC: 2Ey6BW3HMadvA58635z6WDcF4EjwXPA2jaENAroYbqPM
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_USDC_MINT=2Ey6BW3HMadvA58635z6WDcF4EjwXPA2jaENAroYbqPM

# Internal Secret
# Used for API route authentication
INTERNAL_SECRET=your_internal_secret_here

# Admin Key (for development only)
# Points to the authority keypair for admin operations
NEXT_KEYPAIR=scripts/authority-keypair.json
